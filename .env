# ── HuggingFace (téléchargement modèle Gemma4) ───────────────
# Obtenir sur : https://huggingface.co/settings/tokens
HF_TOKEN=hf_glTuXALPcepaMoXhYmsVnFzdYVyScYSpg

# ── ngrok — Tunnel HTTPS vers l'API REST ─────────────────────
# Obtenir sur : https://dashboard.ngrok.com/
NGROK_AUTHTOKEN=3EeFHB5PrLVStD4be1cTcprtnMx_6YWZEq99HtyzDSSRrXMr
NGROK_DOMAIN=theology-custody-rocky.ngrok-free.dev
NGROK_URL=https://theology-custody-rocky.ngrok-free.dev

# ── Arduino — PORT SÉRIE RÉEL ─────────────────────────────────
# Trouver le port : ls /dev/ttyUSB* ou ls /dev/ttyACM*
# Arduino Uno via USB → /dev/ttyUSB0  (la plupart des cas)
# Arduino Nano via USB → /dev/ttyACM0 (parfois)
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=9600
# Pour basculer en simulation : SERIAL_PORT=SIMULATED

# ── Gemma4 — IA locale (llama.cpp) ───────────────────────────
# Fichier modèle GGUF à télécharger avec : make download-gemma4
GEMMA4_VARIANT=e2b
GEMMA4_QUANT=Q4_K_M
GEMMA4_DEST=docker/models/gemma4
GEMMA4_MODEL_FILE=google_gemma-4-E2B-it-Q4_K_M.gguf
GEMMA4_MMPROJ_FILE=mmproj-google_gemma-4-E2B-it-bf16.gguf

# Paramètres llama.cpp
# GEMMA4_HOST : nom du service Docker (gemma4) ou localhost si RPi direct
GEMMA4_HOST=gemma4
GEMMA4_SERVER_PORT=8080
GEMMA4_CTX=4096
GEMMA4_THREADS=4          # RPi4 4 cœurs — laisser 4
GEMMA4_GPU_LAYERS=0       # 0 = CPU seul (RPi4 sans GPU dédié)
GEMMA4_TIMEOUT=45         # secondes max pour une réponse Gemma4
GEMMA4_TEMPERATURE=0.15   # faible = réponses déterministes (sécurité)

# Prompt système Gemma4
GEMMA4_SYSTEM_PROMPT="Tu es un système d'IA embarqué expert en surveillance de réservoirs GNL (Gaz Naturel Liquéfié). Analyse les données capteurs et fournis des décisions de sécurité. Réponds en JSON valide uniquement."

# ── Sélection du fournisseur IA ───────────────────────────────
# gemma4 : Gemma4 local uniquement (hors-ligne, sans coût, recommandé)
GNL_AI_PROVIDER=gemma4

# ── Smart AI — Paramètres d'analyse ──────────────────────────
GNL_AI_INTERVAL=30        # secondes entre analyses routinières
GNL_AI_RISK_TRIGGER=60    # % risque pour déclencher analyse immédiate
GNL_AI_MAX_TOKENS=512     # tokens max réponse (Gemma4 E2B : 512 suffisent)

# ── Watchdog — Sécurité système ───────────────────────────────
WATCHDOG_TIMEOUT_S=5000       # secondes sans données → ESD + shutdown
WATCHDOG_MAX_ERRORS=10        # erreurs pipeline consécutives → shutdown
WATCHDOG_TICK_S=2.0           # intervalle de vérification watchdog (secondes)
WATCHDOG_SENSORS_DEAD_MAX=5   # cycles capteurs HS → ESD préventif
ESD_ACK_TIMEOUT_S=10          # secondes pour acquittement ESD par Arduino
# DANGER : si true → arrêt physique du Raspberry Pi sur défaillance critique
# Mettre true UNIQUEMENT si le RPi peut être redémarré par un timer externe
WATCHDOG_OS_SHUTDOWN=false

# ── Seuils IA (AnomalyEngine + Watchdog) ─────────────────────
GAS_WARN=250
GAS_DANGER=450
LEVEL_HIGH=95
LEVEL_LOW=10
CONFIRM_GAS=3

# ── MongoDB — Historique GNL ─────────────────────────────────────────────────
MONGO_USER=gnl_admin
MONGO_PASS=GNL_Mongo_2025!
MONGO_DB=gnl_history
MONGO_TTL_DAYS=30
MONGO_URI=mongodb://gnl_admin:GNL_Mongo_2025!@mongodb:27017/
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASS=GNL_MongoUI_2025!

# ── InfluxDB ──────────────────────────────────────────────────
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=gnl_influx_token_secret_2025
INFLUX_ORG=gnl_org
INFLUX_BUCKET=gnl_monitoring
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=gnl_admin
DOCKER_INFLUXDB_INIT_PASSWORD=GNL_Influx_2025!
DOCKER_INFLUXDB_INIT_ORG=gnl_org
DOCKER_INFLUXDB_INIT_BUCKET=gnl_monitoring
DOCKER_INFLUXDB_INIT_RETENTION=30d
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=gnl_influx_token_secret_2025

# ── MQTT Mosquitto ────────────────────────────────────────────
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER_PUBLISHER=gnl_publisher
MQTT_PASS_PUBLISHER=GNL_Secure_2025!
MQTT_USER_DASHBOARD=gnl_dashboard
MQTT_PASS_DASHBOARD=GNL_Dash_2025!
MQTT_USER_ADMIN=gnl_admin
MQTT_PASS_ADMIN=GNL_Admin_2025!

# ── Grafana ───────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=gnl_admin
GF_SECURITY_ADMIN_PASSWORD=GNL_Grafana_2025!
GF_USERS_ALLOW_SIGN_UP=false
GF_SERVER_ROOT_URL=https://theology-custody-rocky.ngrok-free.dev/grafana
GF_SERVER_SERVE_FROM_SUB_PATH=true

# ── API REST Flask / JWT ──────────────────────────────────────
GNL_JWT_SECRET=gnl_jwt_secret_change_in_prod
API_HOST=0.0.0.0
API_PORT=5000
